# Base URL of the backend HTTP API (Render URL in prod)
NEXT_PUBLIC_API_URL=http://localhost:1234

# Base WebSocket URL of the backend (wss:// in prod)
NEXT_PUBLIC_WS_URL=ws://localhost:1234

# Public site URL — used for OG/Twitter card absolute URLs (your Vercel domain in prod)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
