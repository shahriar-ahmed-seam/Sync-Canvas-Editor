# HTTP + WebSocket port
PORT=1234

# Redis connection (Render gives you an internal URL)
REDIS_URL=redis://localhost:6379

# Comma-separated list of allowed web origins (Vercel URL in prod)
CORS_ORIGIN=http://localhost:3000

# How often (ms) to persist a board snapshot to Redis
SNAPSHOT_INTERVAL_MS=10000

# How long (seconds) an idle board lives in Redis before expiring. 0 = never expire.
BOARD_TTL_SECONDS=0
